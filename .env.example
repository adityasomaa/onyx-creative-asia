# Supabase — get these from https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Agents dashboard (agents.onyxcreative.asia) — Basic Auth credentials.
# Required in Production. Without them, middleware falls back to onyx/onyx
# (dev-only). See docs/AGENTS.md for setup.
DASHBOARD_USER=onyx
DASHBOARD_PASSWORD=change-me-to-a-long-random-string
