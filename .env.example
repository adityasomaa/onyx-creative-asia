# Supabase — get these from https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Agents dashboard (agents.onyxcreative.asia) — login credentials + HMAC
# secret for session cookies. All three are required in Production.
# DASHBOARD_SECRET signs the session cookie — make it 32+ random chars.
# See docs/AGENTS.md for setup.
DASHBOARD_USER=onyx
DASHBOARD_PASSWORD=change-me-to-a-long-random-string
DASHBOARD_SECRET=change-me-to-32-plus-random-bytes-from-openssl
