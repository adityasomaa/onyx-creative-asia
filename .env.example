# Supabase — get these from https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Agents dashboard (agents.onyxcreative.asia) — login credentials + HMAC
# secret for session cookies. All three are required in Production.
# DASHBOARD_SECRET signs the session cookie — make it 32+ random chars.
# See docs/AGENTS.md for setup.
DASHBOARD_USER=onyx
DASHBOARD_PASSWORD=change-me-to-a-long-random-string
DASHBOARD_SECRET=change-me-to-32-plus-random-bytes-from-openssl

# Resend — transactional email (auto-reply + internal notifications).
# Get key at https://resend.com/api-keys. Verify your domain at
# https://resend.com/domains before sending from hello@onyxcreative.asia.
# If unset, emails are skipped (form still saves to DB).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Onyx Creative Asia <hello@onyxcreative.asia>
INTERNAL_NOTIFY_EMAIL=hello@onyxcreative.asia

# LLM for the agents platform — auto-triage, draft replies, structured
# extraction. Google Gemini via AI Studio (https://aistudio.google.com).
# Free tier model: gemini-2.5-flash. Note: on the free tier Google MAY
# use your prompts/responses for model training. Upgrade to paid to
# disable that. Server-only — never client-side.
GEMINI_API_KEY=your-aistudio-api-key
GEMINI_MODEL=gemini-2.5-flash

# Studio WhatsApp number — used in wa.me links on the website and in
# every outbound email's footer. NEXT_PUBLIC_* so it's available to
# client components. To swap numbers later: change these two + the
# FONNTE_TOKEN below, then redeploy. See docs/AGENTS.md → "Switching
# the WhatsApp number".
NEXT_PUBLIC_WA_NUMBER=62895413372822
NEXT_PUBLIC_WA_DISPLAY=+62 895-4133-72822

# Fonnte — WhatsApp gateway for outbound replies + inbound ingestion.
# Get token at https://md.fonnte.com → Device → Token. Server-only.
FONNTE_TOKEN=your-fonnte-device-token
# Shared secret in the webhook URL: configure Fonnte → Device →
# Webhook with .../api/inbound/whatsapp?secret=<this value>
# Generate with `openssl rand -hex 24` or similar.
FONNTE_WEBHOOK_SECRET=your-random-32-plus-char-secret

# Master kill-switch for the inbound WA webhook. Default OFF.
# When false (or unset), the endpoint returns 200 to Fonnte but
# does NOT insert anything into the submissions table — useful
# while the platform is linked to a personal number you don't want
# leaking into the dashboard. Set "true" + redeploy once the
# dedicated business number is connected.
WA_INBOUND_ENABLED=false

# Whether to auto-reply on inbound WhatsApp messages. Default OFF.
# Set to "true" to enable the "Halo, thanks for the message..." auto-
# reply that fires when a WA chat lands in /agents/submissions.
# Internal email notification to hello@ is always on regardless.
WA_AUTO_REPLY_ENABLED=false

# ---------- WhatsApp safety guards (ban-prevention) ----------
# Every outbound WA send (both operator replies and auto-replies) is
# gated by these limits. Defaults are conservative — only raise them
# once you've burned-in the account for a few weeks without any
# disconnect / flag events on Fonnte.
#
# WA_DAILY_LIMIT — rolling 24h ceiling on successful sends. Default 50.
# WA_PER_RECIPIENT_COOLDOWN_S — min seconds between two sends to the
#   same number. Default 30. Stops accidental double-send.
# WA_MIN_INTERVAL_S — min seconds between ANY two sends device-wide.
#   Default 5. Stops robotic burst-velocity patterns.
# WA_WORKING_HOURS_START / WA_WORKING_HOURS_END — outbound disabled
#   outside this window. 24-hour clock. Default 8 → 22 (8am–10pm).
# WA_WORKING_HOURS_TZ — IANA tz name for the working window.
#   Default Asia/Makassar (WITA / UTC+8).
WA_DAILY_LIMIT=50
WA_PER_RECIPIENT_COOLDOWN_S=30
WA_MIN_INTERVAL_S=5
WA_WORKING_HOURS_START=8
WA_WORKING_HOURS_END=22
WA_WORKING_HOURS_TZ=Asia/Makassar

# Google Analytics 4 Measurement ID for the public marketing site
# (onyxcreative.asia). Wired into src/app/(marketing)/layout.tsx via
# @next/third-parties so it ONLY loads on marketing routes — the
# internal /agents dashboard stays untracked. NEXT_PUBLIC_* so it
# ships to the browser (GA tag is client-side by nature). If unset,
# no tag is loaded (safe for local dev).
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ---------- Project-context credential vault ----------
# AES-256-GCM key used to encrypt the credentials blob stored against
# each WhatsApp chat (wa_chat_context.secrets_*). Generate with:
#   openssl rand -hex 32
# Server-only, never expose to the client. If this key is rotated
# without re-saving every chat's credentials, the existing encrypted
# rows become un-decryptable (the UI surfaces that as an explicit
# "key mismatch — re-enter credentials" state, never silent data loss).
# Minimum length: 32 chars (the helper rejects shorter values).
CHAT_CONTEXT_SECRET=change-me-to-64-hex-chars-from-openssl-rand-hex-32

# Sigap (sub-brand, local.onyxcreative.asia) — budget tier for UMKM.
# WA number for Sigap inquiries. Recommended: use a SEPARATE number
# from NEXT_PUBLIC_WA_NUMBER so Sigap inquiries don't mix with main
# Onyx inquiries in the agents dashboard. If unset, falls back to
# NEXT_PUBLIC_WA_NUMBER (single-channel mode).
NEXT_PUBLIC_SIGAP_WA_NUMBER=62895413372822
NEXT_PUBLIC_SIGAP_WA_DISPLAY=+62 895-4133-72822
# Launch cohort cap. Sigap takes only the first 10 clients at the
# loss-leader prices shown on the landing — after that the page
# flips into "fully booked / waitlist" mode and pricing copy shifts.
# Decrement manually as you close clients; set to 0 to trigger the
# waitlist state. The page falls back to the legacy variable name
# SIGAP_EARLYBIRD_LEFT if SIGAP_SLOTS_LEFT isn't set, so existing
# Vercel values keep working without re-deploy gymnastics.
NEXT_PUBLIC_SIGAP_SLOTS_LEFT=10
